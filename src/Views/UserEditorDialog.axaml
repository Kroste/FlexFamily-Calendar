<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        x:Class="FlexFamilyCalendar.Views.UserEditorDialog"
        x:CompileBindings="False"
        Title="{Binding HeaderText}"
        Width="460" SizeToContent="Height" MaxHeight="840"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <views:UserEditorView />
</views:ChromeWindow>
