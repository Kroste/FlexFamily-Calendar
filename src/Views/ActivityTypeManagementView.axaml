<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cv="using:FlexFamilyCalendar.Converters"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.ActivityTypeManagementView"
             x:CompileBindings="False">

  <UserControl.Resources>
    <cv:ColorStringToBrushConverter x:Key="ColorStringToBrushConverter" />
  </UserControl.Resources>

  <Grid Margin="16" ColumnDefinitions="240,16,*">

    <!-- Liste links -->
    <DockPanel Grid.Column="0">
      <Button DockPanel.Dock="Bottom" Content="{loc:Tr ActType_New}"
              Command="{Binding NewCommand}" Margin="0,8,0,0"
              HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
              Padding="12,7" CornerRadius="6"
              Background="{DynamicResource SystemAccentColor}" Foreground="White" />
      <Border BorderThickness="1" CornerRadius="6"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <ListBox ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="2">
                <Border Width="14" Height="14" CornerRadius="7" VerticalAlignment="Center"
                        Background="{Binding Color, Converter={StaticResource ColorStringToBrushConverter}}" />
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </DockPanel>

    <!-- Formular rechts -->
    <StackPanel Grid.Column="2" Spacing="14">

      <StackPanel Spacing="4">
        <TextBlock Text="{loc:Tr ActType_Name}" FontSize="12" Opacity="0.7" />
        <TextBox Text="{Binding EditName}" CornerRadius="6" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="{loc:Tr ActType_Color}" FontSize="12" Opacity="0.7" />
        <ComboBox ItemsSource="{Binding Colors}" SelectedItem="{Binding EditColor}"
                  HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Width="20" Height="20" CornerRadius="4"
                        Background="{Binding ., Converter={StaticResource ColorStringToBrushConverter}}" />
                <TextBlock Text="{Binding .}" VerticalAlignment="Center" />
              </StackPanel>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="{loc:Tr ActType_Roles}" FontSize="12" Opacity="0.7" />
        <WrapPanel>
          <CheckBox Content="{loc:Tr PersonCategory_Parent}" IsChecked="{Binding EditParent}" Margin="0,0,12,0" />
          <CheckBox Content="{loc:Tr PersonCategory_Child}" IsChecked="{Binding EditChild}" Margin="0,0,12,0" />
          <CheckBox Content="{loc:Tr PersonCategory_Employee}" IsChecked="{Binding EditEmployee}" Margin="0,0,12,0" />
          <CheckBox Content="{loc:Tr PersonCategory_AuPair}" IsChecked="{Binding EditAuPair}" />
        </WrapPanel>
      </StackPanel>

      <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
              Background="#33C0392B" CornerRadius="6" Padding="10,8">
        <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="13" TextWrapping="Wrap" />
      </Border>

      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="{loc:Tr Common_Save}" Command="{Binding SaveCommand}"
                Padding="16,8" CornerRadius="6"
                Background="{DynamicResource SystemAccentColor}" Foreground="White" />
        <Button Content="{loc:Tr Common_Delete}" Command="{Binding DeleteCommand}"
                IsEnabled="{Binding SelectedType, Converter={x:Static ObjectConverters.IsNotNull}}"
                Padding="16,8" CornerRadius="6" Background="#C0392B" Foreground="White" />
      </StackPanel>

    </StackPanel>

  </Grid>
</UserControl>
