<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        xmlns:loc="using:FlexFamilyCalendar.Localization"
        x:Class="FlexFamilyCalendar.Views.ReplanDialog"
        x:CompileBindings="False"
        Title="{loc:Tr Replan_Title}"
        Width="500" SizeToContent="Height" MaxHeight="680"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <views:ReplanView />
</Window>
