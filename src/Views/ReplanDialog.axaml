<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FlexFamilyCalendar.ViewModels"
        xmlns:loc="using:FlexFamilyCalendar.Localization"
        x:Class="FlexFamilyCalendar.Views.ReplanDialog"
        x:CompileBindings="False"
        Title="{loc:Tr Replan_Title}"
        Width="500" SizeToContent="Height" MaxHeight="680"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Grid Margin="24,20,24,20" RowDefinitions="Auto,*,Auto">

    <!-- Kopf: Krankmeldung + Gesund melden -->
    <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,14">
      <TextBlock Text="{loc:Tr Replan_Title}" FontSize="18" FontWeight="Bold" />
      <Border Background="#1AC0392B" CornerRadius="6" Padding="10,8">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="{loc:Tr EntryType_SickLeave}" FontSize="12" Opacity="0.7" />
            <TextBlock Text="{Binding PersonHeader}" FontSize="14" FontWeight="SemiBold" />
          </StackPanel>
          <Button Grid.Column="1" Content="{loc:Tr Replan_MarkHealthy}"
                  Command="{Binding MarkHealthyCommand}"
                  Padding="12,6" CornerRadius="6"
                  Background="#27AE60" Foreground="White" VerticalAlignment="Center" />
        </Grid>
      </Border>
    </StackPanel>

    <StackPanel Grid.Row="1" Spacing="12">

      <!-- Hinweis, wenn keine offene Arbeitsschicht umzuplanen ist -->
      <TextBlock Text="{loc:Tr Replan_NoShift}" FontSize="13" Opacity="0.7"
                 TextWrapping="Wrap" IsVisible="{Binding !HasShift}" />

      <!-- Umplanung (nur bei offener Arbeitsschicht) -->
      <StackPanel Spacing="12" IsVisible="{Binding HasShift}">
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="6" Padding="10,8">
          <StackPanel Spacing="2">
            <TextBlock Text="{loc:Tr Replan_AbsentShift}" FontSize="12" Opacity="0.7" />
            <TextBlock Text="{Binding ShiftLabel}" FontSize="14" FontWeight="SemiBold" />
          </StackPanel>
        </Border>

        <Border Background="#1A2E86C1" CornerRadius="6" Padding="10,8"
                IsVisible="{Binding HasCandidates}">
          <StackPanel Spacing="4">
            <TextBlock Text="🤖 KI" FontSize="12" Opacity="0.7" />
            <TextBlock Text="{Binding AiRecommendation}" FontSize="13" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <TextBlock Text="{loc:Tr Replan_NoCandidates}" FontSize="13" Opacity="0.7"
                   TextWrapping="Wrap" IsVisible="{Binding !HasCandidates}" />

        <ItemsControl ItemsSource="{Binding Candidates}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="6"
                      Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13"
                          Background="{DynamicResource SystemAccentColor}" Margin="0,0,10,0">
                    <TextBlock Text="{Binding Letter}" Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock Text="{Binding Load}" FontSize="11" Opacity="0.7" />
                  </StackPanel>
                  <Button Grid.Column="2" Content="{loc:Tr Replan_TakeOver}"
                          Command="{Binding $parent[ItemsControl].DataContext.TakeOverCommand}"
                          CommandParameter="{Binding}"
                          Padding="12,6" CornerRadius="6"
                          Background="{DynamicResource SystemAccentColor}" Foreground="White"
                          VerticalAlignment="Center" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

    </StackPanel>

    <Button Grid.Row="2" Content="{loc:Tr Common_Cancel}"
            Command="{Binding CancelCommand}" HorizontalAlignment="Right"
            Padding="16,8" CornerRadius="6" Margin="0,16,0,0" />

  </Grid>
</Window>
