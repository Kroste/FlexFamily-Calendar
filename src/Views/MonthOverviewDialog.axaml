<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        xmlns:loc="using:FlexFamilyCalendar.Localization"
        x:Class="FlexFamilyCalendar.Views.MonthOverviewDialog"
        x:CompileBindings="False"
        Title="{loc:Tr Main_MonthOverview}"
        Width="520" Height="600"
        WindowStartupLocation="CenterOwner">
  <views:MonthOverviewView />
</views:ChromeWindow>
