<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlexFamilyCalendar.ViewModels"
             xmlns:cv="using:FlexFamilyCalendar.Converters"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.EntryEditorView"
             x:CompileBindings="False">

  <UserControl.Resources>
    <cv:ColorStringToBrushConverter x:Key="ColorStringToBrushConverter" />
  </UserControl.Resources>

  <Grid Margin="24,20,24,20" RowDefinitions="Auto,*,Auto" MinWidth="432">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="{Binding HeaderText}" FontSize="18" FontWeight="Bold" />
      <TextBlock Text="{Binding DateLabel}" Opacity="0.6" FontSize="13" Margin="0,2,0,0" />
    </StackPanel>

    <!-- Formular -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="600">
      <StackPanel Spacing="14">

        <StackPanel Spacing="4" IsVisible="{Binding CanPickUser}">
          <TextBlock Text="{loc:Tr Entry_User}" FontSize="12" Opacity="0.7" />
          <ComboBox ItemsSource="{Binding AvailableUsers}"
                    SelectedItem="{Binding SelectedUser}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr Entry_Type}" FontSize="12" Opacity="0.7" />
          <ComboBox ItemsSource="{Binding EntryTypes}"
                    SelectedItem="{Binding SelectedType}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <!-- Datumsbereich (nur bei Abwesenheit: Urlaub/Krank/Abwesend) -->
        <Grid ColumnDefinitions="*,16,*" IsVisible="{Binding ShowDateRange}">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="{loc:Tr Entry_DateFrom}" FontSize="12" Opacity="0.7" />
            <DatePicker SelectedDate="{Binding AbsenceFrom}" HorizontalAlignment="Stretch" />
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="4">
            <TextBlock Text="{loc:Tr Entry_DateTo}" FontSize="12" Opacity="0.7" />
            <DatePicker SelectedDate="{Binding AbsenceTo}" HorizontalAlignment="Stretch" />
          </StackPanel>
        </Grid>

        <!-- Aktivitäts-Kategorie (nur bei Typ „Aktivität") -->
        <StackPanel Spacing="4" IsVisible="{Binding ShowActivityType}">
          <TextBlock Text="{loc:Tr Entry_ActivityType}" FontSize="12" Opacity="0.7" />
          <ComboBox ItemsSource="{Binding AvailableActivityTypes}"
                    SelectedItem="{Binding SelectedActivityType}"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="{loc:Tr Entry_ActivityNone}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border Width="16" Height="16" CornerRadius="8" VerticalAlignment="Center"
                          Background="{Binding Color, Converter={StaticResource ColorStringToBrushConverter}}" />
                  <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <Grid ColumnDefinitions="*,16,*">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="{loc:Tr Entry_StartTime}" FontSize="12" Opacity="0.7" />
            <TimePicker SelectedTime="{Binding StartTime}"
                        ClockIdentifier="24HourClock"
                        HorizontalAlignment="Stretch" />
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="4">
            <TextBlock Text="{loc:Tr Entry_EndTime}" FontSize="12" Opacity="0.7" />
            <TimePicker SelectedTime="{Binding EndTime}"
                        ClockIdentifier="24HourClock"
                        HorizontalAlignment="Stretch" />
          </StackPanel>
        </Grid>

        <Border IsVisible="{Binding ShowOvernightNote}"
                Background="#225B4B8A" CornerRadius="6" Padding="10,8">
          <TextBlock Text="{Binding OvernightNote}" FontSize="12" TextWrapping="Wrap" />
        </Border>

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr Entry_TitleLabel}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding Title}"
                   PlaceholderText="{loc:Tr Entry_TitlePlaceholder}"
                   CornerRadius="6" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr Entry_NotesLabel}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding Notes}"
                   PlaceholderText="{loc:Tr Entry_NotesPlaceholder}"
                   AcceptsReturn="True"
                   Height="80"
                   TextWrapping="Wrap"
                   CornerRadius="6" />
        </StackPanel>

        <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="#33C0392B" CornerRadius="6" Padding="10,8">
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="13" TextWrapping="Wrap" />
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- Buttons -->
    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,12,Auto" Margin="0,16,0,0">
      <Button Grid.Column="0"
              Content="{loc:Tr Common_Delete}"
              Command="{Binding DeleteCommand}"
              IsVisible="{Binding IsEditMode}"
              Padding="16,8" CornerRadius="6"
              Background="#C0392B" Foreground="White" />
      <Button Grid.Column="2"
              Content="{loc:Tr Common_Cancel}"
              Command="{Binding CancelCommand}"
              Padding="16,8" CornerRadius="6" />
      <Button Grid.Column="4"
              Content="{loc:Tr Common_Save}"
              Command="{Binding SaveCommand}"
              Padding="16,8" CornerRadius="6"
              Background="{DynamicResource SystemAccentColor}" Foreground="White" />
    </Grid>

  </Grid>
</UserControl>
