<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.MoveCopyView"
             x:CompileBindings="False">

  <Grid Margin="24,20,24,20" RowDefinitions="Auto,Auto,Auto" MinWidth="400">

    <TextBlock Grid.Row="0" Text="{Binding HeaderText}"
               FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

    <TextBlock Grid.Row="1" Text="{Binding Description}"
               Opacity="0.8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,18" />

    <StackPanel Grid.Row="2" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="12">
      <Button Content="{loc:Tr Common_Cancel}"
              Command="{Binding CancelCommand}"
              Padding="16,8" CornerRadius="6" />
      <Button Content="{loc:Tr MoveCopy_Copy}"
              Command="{Binding CopyCommand}"
              Padding="16,8" CornerRadius="6" />
      <Button Content="{loc:Tr MoveCopy_Move}"
              Command="{Binding MoveCommand}"
              Padding="16,8" CornerRadius="6"
              Background="{DynamicResource SystemAccentColor}" Foreground="White" />
    </StackPanel>

  </Grid>
</UserControl>
