<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlexFamilyCalendar.ViewModels"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.MonthOverviewView"
             x:CompileBindings="False">

  <DockPanel Margin="20" MinWidth="480" Height="600">

    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Main_MonthOverview}"
               FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

    <!-- Monatsnavigation -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
      <Button Grid.Column="0" Content="{loc:Tr Month_Previous}"
              Command="{Binding PreviousMonthCommand}" Padding="12,6" CornerRadius="6" />
      <TextBlock Grid.Column="1" Text="{Binding MonthLabel}"
                 FontSize="16" FontWeight="SemiBold"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
      <Button Grid.Column="2" Content="{loc:Tr Month_Next}"
              Command="{Binding NextMonthCommand}" Padding="12,6" CornerRadius="6" />
    </Grid>

    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Rows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,12" Padding="12,10" CornerRadius="6"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
              <StackPanel Spacing="6">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" />
                <ProgressBar Minimum="0" Maximum="{Binding Target}" Value="{Binding Actual}"
                             Height="10" CornerRadius="5"
                             IsVisible="{Binding HasTarget}"
                             Foreground="{Binding BarColor, Converter={StaticResource ColorStringToBrushConverter}}" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="{Binding Summary}" FontSize="13" Opacity="0.8" />
                  <TextBlock Grid.Column="1" Text="{Binding Difference}" FontSize="13" FontWeight="SemiBold"
                             IsVisible="{Binding HasTarget}"
                             Foreground="{Binding BarColor, Converter={StaticResource ColorStringToBrushConverter}}" />
                </Grid>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
