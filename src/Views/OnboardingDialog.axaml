<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        xmlns:vm="using:FlexFamilyCalendar.ViewModels"
        xmlns:loc="using:FlexFamilyCalendar.Localization"
        x:Class="FlexFamilyCalendar.Views.OnboardingDialog"
        x:DataType="vm:OnboardingViewModel"
        x:CompileBindings="False"
        Title="{loc:Tr Onboarding_Title}"
        SizeToContent="WidthAndHeight"
        CanResize="True"
        MinWidth="480" MinHeight="320"
        WindowStartupLocation="CenterOwner">

  <views:OnboardingView />

</views:ChromeWindow>
