<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        x:Class="FlexFamilyCalendar.Views.RecurrencePauseDialog"
        x:CompileBindings="False"
        Title="{Binding RuleTitle}"
        Width="540" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <views:RecurrencePauseView />
</views:ChromeWindow>
