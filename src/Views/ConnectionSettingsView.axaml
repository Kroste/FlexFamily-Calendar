<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.ConnectionSettingsView"
             x:CompileBindings="False">

  <Grid Margin="24,20,24,20" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" MinWidth="420">

    <StackPanel Grid.Row="0" Margin="0,0,0,12">
      <TextBlock Text="{loc:Tr Connection_Title}" FontSize="18" FontWeight="Bold" />
      <TextBlock Text="{loc:Tr Connection_Subtitle}" Opacity="0.65" FontSize="13" Margin="0,2,0,0"
                 TextWrapping="Wrap" />
    </StackPanel>

    <CheckBox Grid.Row="1" Content="{loc:Tr Connection_UseServer}" IsChecked="{Binding UseServer}" />

    <StackPanel Grid.Row="2" Spacing="4" Margin="0,10,0,0" IsVisible="{Binding UseServer}">
      <TextBlock Text="{loc:Tr Connection_ServerUrl}" FontSize="12" Opacity="0.7" />
      <TextBox Text="{Binding ServerUrl}" CornerRadius="6"
               PlaceholderText="https://flexfamily.cloud" />
    </StackPanel>

    <TextBlock Grid.Row="3" Text="{loc:Tr Connection_RestartHint}" FontSize="12" Opacity="0.6"
               Margin="0,12,0,0" TextWrapping="Wrap" />

    <Border Grid.Row="4" Background="#33C0392B" CornerRadius="6" Padding="10,7" Margin="0,10,0,0"
            IsVisible="{Binding ErrorMessage.Length}">
      <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="13" />
    </Border>

    <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="12"
                HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="{loc:Tr Common_Cancel}" Command="{Binding CancelCommand}"
              Padding="16,8" CornerRadius="6" />
      <Button Content="{loc:Tr Common_Save}" Command="{Binding SaveCommand}"
              Padding="16,8" CornerRadius="6"
              Background="{DynamicResource SystemAccentColor}" Foreground="White" />
    </StackPanel>

  </Grid>
</UserControl>
