<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:FlexFamilyCalendar.Views"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.AdminView"
             x:CompileBindings="False">

  <TabControl Margin="8" MinWidth="860" Height="620">
    <TabItem Header="{loc:Tr Main_UserManagement}">
      <views:UserManagementView DataContext="{Binding Users}" />
    </TabItem>
    <TabItem Header="{loc:Tr Main_ActivityTypes}">
      <views:ActivityTypeManagementView DataContext="{Binding Categories}" />
    </TabItem>
    <TabItem Header="{loc:Tr Main_RecurringActivities}">
      <views:RecurringActivityManagementView DataContext="{Binding Recurring}" />
    </TabItem>
    <TabItem Header="{loc:Tr Main_Settings}">
      <views:SettingsView DataContext="{Binding Settings}" />
    </TabItem>
    <TabItem Header="{loc:Tr Main_AiSettings}">
      <views:AiSettingsView DataContext="{Binding Ai}" />
    </TabItem>
  </TabControl>
</UserControl>
