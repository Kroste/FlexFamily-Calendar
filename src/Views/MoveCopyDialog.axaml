<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        xmlns:loc="using:FlexFamilyCalendar.Localization"
        x:Class="FlexFamilyCalendar.Views.MoveCopyDialog"
        x:CompileBindings="False"
        Title="{loc:Tr MoveCopy_Title}"
        Width="440" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <views:MoveCopyView />
</views:ChromeWindow>
