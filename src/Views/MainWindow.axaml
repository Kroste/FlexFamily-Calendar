<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FlexFamilyCalendar.ViewModels"
        xmlns:views="using:FlexFamilyCalendar.Views"
        x:Class="FlexFamilyCalendar.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Icon="/Assets/avalonia-logo.ico"
        Title="FlexFamily Calendar"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600">
  <views:MainView />
</views:ChromeWindow>
