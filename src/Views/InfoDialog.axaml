<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        xmlns:vm="using:FlexFamilyCalendar.ViewModels"
        xmlns:loc="using:FlexFamilyCalendar.Localization"
        x:Class="FlexFamilyCalendar.Views.InfoDialog"
        x:DataType="vm:InfoViewModel"
        x:CompileBindings="False"
        Title="{loc:Tr Info_Title}"
        SizeToContent="WidthAndHeight"
        CanResize="True"
        MinWidth="380" MinHeight="240"
        WindowStartupLocation="CenterOwner">

  <views:InfoView />

</views:ChromeWindow>
