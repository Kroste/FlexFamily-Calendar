<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        xmlns:loc="using:FlexFamilyCalendar.Localization"
        x:Class="FlexFamilyCalendar.Views.ConnectionSettingsDialog"
        x:CompileBindings="False"
        Title="{loc:Tr Connection_Title}"
        Width="480" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <views:ConnectionSettingsView />
</Window>
