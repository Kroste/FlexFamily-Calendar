<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FlexFamilyCalendar.ViewModels"
        xmlns:loc="using:FlexFamilyCalendar.Localization"
        x:Class="FlexFamilyCalendar.Views.UserManagementDialog"
        x:CompileBindings="False"
        Title="{loc:Tr Main_UserManagement}"
        Width="560" Height="560"
        WindowStartupLocation="CenterOwner">

  <DockPanel Margin="20">

    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Main_UserManagement}"
               FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

    <!-- Toolbar -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
      <Button Content="{loc:Tr User_New}" Command="{Binding NewUserCommand}"
              Padding="14,7" CornerRadius="6"
              Background="{DynamicResource SystemAccentColor}" Foreground="White" />
      <Button Content="{loc:Tr User_Edit}" Command="{Binding EditUserCommand}"
              IsEnabled="{Binding SelectedUser, Converter={x:Static ObjectConverters.IsNotNull}}"
              Padding="14,7" CornerRadius="6" />
      <Button Content="{loc:Tr Common_Delete}" Command="{Binding DeleteUserCommand}"
              IsEnabled="{Binding SelectedUser, Converter={x:Static ObjectConverters.IsNotNull}}"
              Padding="14,7" CornerRadius="6" Background="#C0392B" Foreground="White" />
    </StackPanel>

    <Border DockPanel.Dock="Bottom"
            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="#33C0392B" CornerRadius="6" Padding="10,8" Margin="0,12,0,0">
      <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="13" TextWrapping="Wrap" />
    </Border>

    <!-- Benutzerliste -->
    <Border BorderThickness="1" CornerRadius="6"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
      <ListBox ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
               Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto" Margin="4,2">
              <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Username}" FontSize="11" Opacity="0.6" />
              </StackPanel>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock Text="{Binding Role}" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" />
                <TextBlock Text="{Binding Category}" FontSize="11" Opacity="0.5" HorizontalAlignment="Right" />
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

  </DockPanel>
</Window>
