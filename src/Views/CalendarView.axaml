<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlexFamilyCalendar.ViewModels"
             xmlns:models="using:FlexFamilyCalendar.Models"
             xmlns:cv="using:FlexFamilyCalendar.Converters"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.CalendarView"
             x:CompileBindings="False">

  <UserControl.Resources>
    <cv:ColorStringToBrushConverter x:Key="ColorStringToBrushConverter" />
  </UserControl.Resources>

  <DockPanel>

    <!-- View-As-Banner: Admin schaut aus der Sicht einer anderen Person -->
    <Border DockPanel.Dock="Top" Background="#E67E22" Padding="14,8"
            IsVisible="{Binding IsImpersonating}">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="{Binding ViewAsBanner}" Foreground="White"
                   FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
        <Button Grid.Column="1" Content="{loc:Tr Cal_ExitViewAs}" Command="{Binding ExitImpersonationCommand}"
                Padding="12,6" CornerRadius="6"
                Background="White" Foreground="#E67E22" FontWeight="SemiBold" />
      </Grid>
    </Border>

    <!-- Wochennavigation -->
    <Border DockPanel.Dock="Top"
            Padding="12,8"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
        <Button Grid.Column="0" Content="{loc:Tr Cal_PreviousWeek}"
                Command="{Binding PreviousWeekCommand}" Padding="12,6" CornerRadius="6" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
          <ToggleButton Content="{loc:Tr Cal_ViewPersonal}"
                        IsChecked="{Binding IsPersonalView}"
                        IsVisible="{Binding CanSwitchView}"
                        Padding="12,6" CornerRadius="6" />
          <Button Content="{loc:Tr Cal_HoursToggle}"
                  Command="{Binding ToggleHoursPanelCommand}"
                  Padding="12,6" CornerRadius="6" />
          <ToggleButton Content="{loc:Tr Cal_Holidays}"
                        IsChecked="{Binding IsHolidaysVisible}"
                        Padding="12,6" CornerRadius="6" />
          <Button Content="{loc:Tr Cal_ExportPdf}"
                  Command="{Binding ExportPdfCommand}"
                  Padding="12,6" CornerRadius="6" />
          <Button Content="{loc:Tr Cal_Mail}"
                  Command="{Binding MailPlanCommand}"
                  IsVisible="{Binding EffectiveIsAdmin}"
                  Padding="12,6" CornerRadius="6" />
          <Button Content="{loc:Tr Cal_AiPlanner}"
                  Command="{Binding OpenAiPlannerCommand}"
                  IsVisible="{Binding EffectiveIsAdmin}"
                  Padding="12,6" CornerRadius="6" />
          <Button Content="{loc:Tr Cal_CopyWeek}"
                  Command="{Binding CopyWeekToNextCommand}"
                  IsVisible="{Binding EffectiveIsAdmin}"
                  Padding="12,6" CornerRadius="6" />
          <Button Content="{Binding FinalizeButtonKey, Converter={x:Static loc:LocKeyConverter.Instance}}"
                  Command="{Binding ToggleFinalizeWeekCommand}"
                  IsVisible="{Binding EffectiveIsAdmin}"
                  Padding="12,6" CornerRadius="6" />
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding WeekLabel}"
                   FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
        <Button Grid.Column="3" Content="{loc:Tr Cal_Today}"
                Command="{Binding GoToTodayCommand}" Padding="12,6" CornerRadius="6" Margin="0,0,8,0" />
        <Button Grid.Column="4" Content="{loc:Tr Cal_NextWeek}"
                Command="{Binding NextWeekCommand}" Padding="12,6" CornerRadius="6" />
      </Grid>
    </Border>

    <!-- Wochenstunden-Panel (Admin, einklappbar) -->
    <Border DockPanel.Dock="Right"
            IsVisible="{Binding IsHoursPanelVisible}"
            Width="250"
            BorderThickness="1,0,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="{DynamicResource SystemControlBackgroundChromeLowBrush}">
      <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Cal_HoursTitle}"
                   FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding WeeklyHours}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,12" Padding="10,8" CornerRadius="6"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                  <StackPanel Spacing="5">
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" />
                    <ProgressBar Minimum="0" Maximum="{Binding Target}" Value="{Binding Actual}"
                                 Height="8" CornerRadius="4"
                                 IsVisible="{Binding HasTarget}"
                                 Foreground="{Binding BarColor, Converter={StaticResource ColorStringToBrushConverter}}" />
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Text="{Binding Summary}" FontSize="12" Opacity="0.8" />
                      <TextBlock Grid.Column="1" Text="{Binding Difference}" FontSize="12" FontWeight="SemiBold"
                                 IsVisible="{Binding HasTarget}"
                                 Foreground="{Binding BarColor, Converter={StaticResource ColorStringToBrushConverter}}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Warnings}" IsVisible="{Binding HasWarnings}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold"
                                     Foreground="#C0392B" TextWrapping="Wrap" Margin="0,2,0,0" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- Tabellen-Plan: Personen (Zeilen) × Wochentage (Spalten) -->
    <DockPanel>

      <!-- Spaltenkopf: leere Ecke (160px) + 7 Tagesköpfe -->
      <Grid DockPanel.Dock="Top" ColumnDefinitions="160,*"
            Background="{DynamicResource SystemControlBackgroundChromeLowBrush}">
        <Border Grid.Column="0" BorderThickness="0,0,1,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" />
        <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><UniformGrid Columns="7" /></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Padding="4,6" BorderThickness="1,0,0,1"
                      BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                <StackPanel HorizontalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding DayName}" HorizontalAlignment="Center" FontSize="13" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding DateLabel}" HorizontalAlignment="Center" FontSize="12" Opacity="0.7" />
                  <TextBlock Text="{Binding HolidayName}" IsVisible="{Binding ShowHoliday}"
                             HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                             FontSize="11" FontWeight="SemiBold" Foreground="#E67E22" />
                  <Border IsVisible="{Binding IsToday}" Background="{DynamicResource SystemAccentColor}"
                          CornerRadius="3" Padding="6,1">
                    <TextBlock Text="{loc:Tr Cal_TodayBadge}" FontSize="10" Foreground="White" />
                  </Border>
                  <Border IsVisible="{Binding IsFinalized}" Background="#27AE60" CornerRadius="3" Padding="6,1">
                    <TextBlock Text="{loc:Tr Cal_FinalBadge}" FontSize="10" Foreground="White" />
                  </Border>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>

      <!-- Hinweiszeile unten: Feiertag-Notizen, sitzt direkt unter den (das Fenster füllenden) Zeilen -->
      <Grid DockPanel.Dock="Bottom" ColumnDefinitions="160,*"
            Background="{DynamicResource SystemControlBackgroundChromeLowBrush}">
        <Border Grid.Column="0" BorderThickness="0,1,1,1" Padding="8,4"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
          <TextBlock Text="{loc:Tr Cal_Hints}" FontSize="11" FontWeight="SemiBold" Opacity="0.7"
                     VerticalAlignment="Center" />
        </Border>
        <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><UniformGrid Columns="7" /></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderThickness="1,1,0,1" Padding="4,4" MinHeight="34"
                      BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                <Grid>
                  <!-- Hinweistext als gelber Sticky-Note-Block, deutlich abgehoben -->
                  <Border IsVisible="{Binding HasNote}"
                          Background="#FFF6BE" BorderBrush="#E0B400" BorderThickness="1"
                          CornerRadius="4" Padding="6,3" Margin="2,1">
                    <TextBlock Text="{Binding DayNote}"
                               TextAlignment="Center" TextWrapping="Wrap"
                               FontSize="13" FontWeight="SemiBold" Foreground="#664D00"
                               VerticalAlignment="Center" />
                  </Border>
                  <Button Content="✎" Command="{Binding EditNoteCommand}" IsVisible="{Binding CanEditNote}"
                          FontSize="11" Padding="4,0" CornerRadius="3"
                          Background="Transparent" Opacity="0.5"
                          HorizontalAlignment="Right" VerticalAlignment="Top"
                          ToolTip.Tip="{loc:Tr DayNote_Title}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>

      <!-- Personenzeilen — füllen die verbleibende Fensterhöhe (gleichmäßig) -->
      <ItemsControl ItemsSource="{Binding Rows}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate><UniformGrid Columns="1" /></ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="160,*">

                <!-- Person — Klick (Admin) schaltet die Sicht in ihre Perspektive -->
                <Button Grid.Column="0" Padding="0" Background="Transparent" BorderThickness="0"
                        Command="{Binding ImpersonateCommand}" IsEnabled="{Binding CanImpersonate}"
                        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                        Cursor="Hand">
                  <Border BorderThickness="0,0,1,1" Padding="8,6"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <Border Width="11" Height="11" CornerRadius="5.5" VerticalAlignment="Center"
                              Background="{Binding Color, Converter={StaticResource ColorStringToBrushConverter}}" />
                      <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding CategoryLabel}" FontSize="10" Opacity="0.6" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </Button>

                <!-- 7 Tageszellen -->
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><UniformGrid Columns="7" /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderThickness="1,0,0,1" MinHeight="46" Padding="3" Cursor="Hand"
                              Tapped="OnCellTapped" Background="Transparent" ClipToBounds="True"
                              DragDrop.AllowDrop="True" Loaded="OnCellLoaded"
                              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <Grid>
                          <Border IsVisible="{Binding IsToday}" Background="#142E86C1" />
                          <TextBlock Text="+" IsVisible="{Binding ShowAddHint}" Opacity="0.22" FontSize="16"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />

                          <ItemsControl ItemsSource="{Binding Entries}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border CornerRadius="4" Padding="4,2" Margin="0,0,0,2" Cursor="Hand"
                                        Tapped="OnEntryTapped"
                                        PointerPressed="OnEntryPointerPressed"
                                        PointerMoved="OnEntryPointerMoved"
                                        PointerReleased="OnEntryPointerReleased"
                                        ClipToBounds="True"
                                        Opacity="{Binding DisplayOpacity}"
                                        Background="{Binding OwnerColor, Converter={StaticResource ColorStringToBrushConverter}}">
                                  <Grid>
                                    <StackPanel Spacing="0">
                                      <TextBlock Text="{Binding TimeRange}" FontSize="9.5" Foreground="White" Opacity="0.85"
                                                 IsVisible="{Binding ShowsTime}" />
                                      <TextBlock Text="{Binding DisplayType, Converter={x:Static cv:EntryTypeLabelConverter.Instance}}"
                                                 FontSize="11" FontWeight="SemiBold" Foreground="White"
                                                 TextTrimming="CharacterEllipsis" IsVisible="{Binding ShowsTypeLabel}" />
                                      <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding HasActivity}">
                                        <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                                BorderBrush="#E6FFFFFF" BorderThickness="1"
                                                Background="{Binding ActivityColor, Converter={StaticResource ColorStringToBrushConverter}}" />
                                        <TextBlock Text="{Binding ActivityName}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White" TextTrimming="CharacterEllipsis" />
                                      </StackPanel>
                                      <TextBlock Text="{Binding DisplayTitle}" FontSize="10.5" Foreground="White" Opacity="0.9"
                                                 TextTrimming="CharacterEllipsis"
                                                 IsVisible="{Binding DisplayTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                      <TextBlock Text="{Binding AbsenceSpanLabel}" FontSize="10" Foreground="White" Opacity="0.85"
                                                 IsVisible="{Binding ShowAbsenceSpan}" />
                                      <TextBlock Text="{loc:Tr Recur_HolidayHint}" IsVisible="{Binding HolidayConflict}"
                                                 FontSize="9.5" FontStyle="Italic" Foreground="White" Opacity="0.95"
                                                 TextWrapping="Wrap" />
                                      <TextBlock Text="{loc:Tr RecurrencePause_PausedSuffix}" IsVisible="{Binding IsPaused}"
                                                 FontSize="9.5" FontStyle="Italic" Foreground="White" Opacity="0.95" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="2"
                                                HorizontalAlignment="Right" VerticalAlignment="Top">
                                      <Border IsVisible="{Binding IsRecurring}" Background="#33000000" CornerRadius="3" Padding="2,0"
                                              ToolTip.Tip="{loc:Tr Recur_Title}">
                                        <TextBlock Text="↻" FontSize="10" Foreground="White" />
                                      </Border>
                                      <Border IsVisible="{Binding HasSwap}" Background="#CC000000" CornerRadius="3" Padding="2,0">
                                        <TextBlock Text="⇄" FontSize="10" Foreground="White" />
                                      </Border>
                                    </StackPanel>
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

    </DockPanel>

  </DockPanel>
</UserControl>
