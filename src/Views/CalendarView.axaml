<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlexFamilyCalendar.ViewModels"
             xmlns:models="using:FlexFamilyCalendar.Models"
             xmlns:cv="using:FlexFamilyCalendar.Converters"
             xmlns:ctrl="using:FlexFamilyCalendar.Controls"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.CalendarView"
             x:CompileBindings="False">

  <UserControl.Resources>
    <cv:ColorStringToBrushConverter x:Key="ColorStringToBrushConverter" />
  </UserControl.Resources>

  <DockPanel>

    <!-- Wochennavigation -->
    <Border DockPanel.Dock="Top"
            Padding="12,8"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
        <Button Grid.Column="0" Content="{loc:Tr Cal_PreviousWeek}"
                Command="{Binding PreviousWeekCommand}" Padding="12,6" CornerRadius="6" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
          <ToggleButton Content="{loc:Tr Cal_ViewPersonal}"
                        IsChecked="{Binding IsPersonalView}"
                        IsVisible="{Binding CanSwitchView}"
                        Padding="12,6" CornerRadius="6" />
          <Button Content="{loc:Tr Cal_HoursToggle}"
                  Command="{Binding ToggleHoursPanelCommand}"
                  Padding="12,6" CornerRadius="6" />
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding WeekLabel}"
                   FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
        <Button Grid.Column="3" Content="{loc:Tr Cal_Today}"
                Command="{Binding GoToTodayCommand}" Padding="12,6" CornerRadius="6" Margin="0,0,8,0" />
        <Button Grid.Column="4" Content="{loc:Tr Cal_NextWeek}"
                Command="{Binding NextWeekCommand}" Padding="12,6" CornerRadius="6" />
      </Grid>
    </Border>

    <!-- Sticky-Header: leere Ecke (56px) + 7 Tagesköpfe -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="56,*"
          Background="{DynamicResource SystemControlBackgroundChromeLowBrush}">
      <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate><UniformGrid Columns="7" /></ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Padding="4,6"
                    BorderThickness="1,0,0,1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
              <StackPanel HorizontalAlignment="Center" Spacing="3">
                <TextBlock Text="{Binding DayName}" HorizontalAlignment="Center" FontSize="13" FontWeight="SemiBold" />
                <TextBlock Text="{Binding DateLabel}" HorizontalAlignment="Center" FontSize="12" Opacity="0.7" />
                <Border IsVisible="{Binding IsToday}" Background="{DynamicResource SystemAccentColor}"
                        CornerRadius="3" Padding="6,1">
                  <TextBlock Text="{loc:Tr Cal_TodayBadge}" FontSize="10" Foreground="White" />
                </Border>
                <Border IsVisible="{Binding IsFinalized}" Background="#27AE60" CornerRadius="3" Padding="6,1">
                  <TextBlock Text="{loc:Tr Cal_FinalBadge}" FontSize="10" Foreground="White" />
                </Border>
                <Button Content="{loc:Tr Cal_AddEntry}"
                        Command="{Binding AddEntryCommand}"
                        IsVisible="{Binding CanAddEntry}"
                        IsEnabled="{Binding !IsFinalized}"
                        Padding="6,2" FontSize="11" CornerRadius="4"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>

    <!-- Wochenstunden-Panel (Admin, einklappbar) -->
    <Border DockPanel.Dock="Right"
            IsVisible="{Binding IsHoursPanelVisible}"
            Width="250"
            BorderThickness="1,0,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="{DynamicResource SystemControlBackgroundChromeLowBrush}">
      <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Cal_HoursTitle}"
                   FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding WeeklyHours}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,12" Padding="10,8" CornerRadius="6"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                  <StackPanel Spacing="5">
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" />
                    <ProgressBar Minimum="0" Maximum="{Binding Target}" Value="{Binding Actual}"
                                 Height="8" CornerRadius="4"
                                 IsVisible="{Binding HasTarget}"
                                 Foreground="{Binding BarColor, Converter={StaticResource ColorStringToBrushConverter}}" />
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Text="{Binding Summary}" FontSize="12" Opacity="0.8" />
                      <TextBlock Grid.Column="1" Text="{Binding Difference}" FontSize="12" FontWeight="SemiBold"
                                 IsVisible="{Binding HasTarget}"
                                 Foreground="{Binding BarColor, Converter={StaticResource ColorStringToBrushConverter}}" />
                    </Grid>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- Scrollbares 24h-Raster: Zeitachse (56px) + 7 Tagesspalten -->
    <ScrollViewer x:Name="GridScroll"
                  HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
      <Grid ColumnDefinitions="56,*">

        <!-- Zeitachse -->
        <ItemsControl Grid.Column="0" ItemsSource="{x:Static ctrl:CalendarMetrics.HourLabels}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Height="48" BorderThickness="0,0,0,1"
                      BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                <TextBlock Text="{Binding}" FontSize="11" Opacity="0.6"
                           HorizontalAlignment="Right" VerticalAlignment="Top"
                           Margin="0,-7,6,0" />
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Tagesspalten -->
        <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><UniformGrid Columns="7" /></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid>
                <!-- Heute-Tönung -->
                <Border IsVisible="{Binding IsToday}" Background="#142E86C1" />

                <!-- Stundenraster -->
                <ItemsControl ItemsSource="{x:Static ctrl:CalendarMetrics.HourLabels}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Height="48" BorderThickness="1,0,0,1"
                              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Einträge, zeitbasiert positioniert -->
                <ItemsControl ItemsSource="{Binding Entries}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><ctrl:DayTimelinePanel /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="5" Padding="5,3" Margin="0" ClipToBounds="True"
                              Cursor="Hand" Tapped="OnEntryTapped"
                              Opacity="{Binding EffectiveOpacity}"
                              BorderBrush="#E6FFFFFF"
                              BorderThickness="{Binding IsHighlighted, Converter={x:Static cv:BoolToThicknessConverter.Instance}}"
                              Background="{Binding OwnerColor, Converter={StaticResource ColorStringToBrushConverter}}">
                        <StackPanel Spacing="0">
                          <TextBlock Text="{Binding TimeRange}" FontSize="10" Foreground="White" Opacity="0.85" />
                          <TextBlock Text="{Binding Type, Converter={x:Static cv:EntryTypeLabelConverter.Instance}}"
                                     FontSize="11" FontWeight="SemiBold"
                                     Foreground="White" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding Title}" FontSize="11" Foreground="White" Opacity="0.9"
                                     TextTrimming="CharacterEllipsis"
                                     IsVisible="{Binding Title, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                          <TextBlock Text="{Binding UserDisplayName}" FontSize="10" Foreground="White" Opacity="0.8"
                                     TextTrimming="CharacterEllipsis"
                                     IsVisible="{Binding UserDisplayName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </Grid>
    </ScrollViewer>

  </DockPanel>
</UserControl>
