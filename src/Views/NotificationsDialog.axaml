<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        xmlns:loc="using:FlexFamilyCalendar.Localization"
        x:Class="FlexFamilyCalendar.Views.NotificationsDialog"
        x:CompileBindings="False"
        Title="{loc:Tr Notif_Title}"
        Width="480" Height="560"
        WindowStartupLocation="CenterOwner">
  <views:NotificationsView />
</views:ChromeWindow>
