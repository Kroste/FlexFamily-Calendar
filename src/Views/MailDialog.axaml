<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        xmlns:loc="using:FlexFamilyCalendar.Localization"
        x:Class="FlexFamilyCalendar.Views.MailDialog"
        x:CompileBindings="False"
        Title="{loc:Tr Mail_Title}"
        Width="440" Height="480"
        WindowStartupLocation="CenterOwner">
  <views:MailView />
</views:ChromeWindow>
