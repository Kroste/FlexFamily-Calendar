<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FlexFamilyCalendar.Views"
        x:Class="FlexFamilyCalendar.Views.EntryEditorDialog"
        x:CompileBindings="False"
        Title="{Binding HeaderText}"
        Width="480" SizeToContent="Height" MaxHeight="760"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <views:EntryEditorView />
</views:ChromeWindow>
