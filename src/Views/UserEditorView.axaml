<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlexFamilyCalendar.ViewModels"
             xmlns:cv="using:FlexFamilyCalendar.Converters"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.UserEditorView"
             x:CompileBindings="False">

  <UserControl.Resources>
    <cv:ColorStringToBrushConverter x:Key="ColorStringToBrushConverter" />
    <cv:HexToColorConverter x:Key="HexToColorConverter" />
  </UserControl.Resources>

  <Grid Margin="24,20,24,20" RowDefinitions="Auto,*,Auto" MinWidth="412">

    <TextBlock Grid.Row="0" Text="{Binding HeaderText}" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="640">
      <StackPanel Spacing="14">

        <StackPanel Spacing="4" IsVisible="{Binding CanEditAdminFields}">
          <TextBlock Text="{loc:Tr User_Username}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding Username}" CornerRadius="6" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr User_DisplayName}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding DisplayName}" CornerRadius="6" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr User_Email}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding Email}" CornerRadius="6" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr User_Language}" FontSize="12" Opacity="0.7" />
          <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding CanEditAdminFields}">
          <TextBlock Text="{loc:Tr User_Role}" FontSize="12" Opacity="0.7" />
          <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}"
                    IsEnabled="{Binding IsRoleEditable}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding CanEditAdminFields}">
          <TextBlock Text="{loc:Tr User_Category}" FontSize="12" Opacity="0.7" />
          <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding CanEditAdminFields}">
          <TextBlock Text="{loc:Tr User_WeeklyHours}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding WeeklyHours}" CornerRadius="6" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding CanEditAdminFields}">
          <TextBlock Text="{loc:Tr User_MaxWeeklyHours}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding MaxWeeklyHours}" CornerRadius="6" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding CanEditAdminFields}">
          <TextBlock Text="{loc:Tr User_MaxDailyHours}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding MaxDailyHours}" CornerRadius="6" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding CanEditAdminFields}">
          <TextBlock Text="{loc:Tr User_MinRestHours}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding MinRestHours}" CornerRadius="6" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding CanEditAdminFields}">
          <TextBlock Text="{loc:Tr User_OpeningBalance}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding OpeningBalance}" CornerRadius="6" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding CanEditAdminFields}">
          <TextBlock Text="{loc:Tr User_AccountStart}" FontSize="12" Opacity="0.7" />
          <DatePicker SelectedDate="{Binding AccountStart}" HorizontalAlignment="Stretch" />
        </StackPanel>

        <!-- Theme pro Benutzer -->
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr User_Theme}" FontSize="12" Opacity="0.7" />
          <ComboBox ItemsSource="{Binding ThemeVariants}" SelectedItem="{Binding SelectedThemeVariant}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate><TextBlock Text="{Binding LabelKey, Converter={x:Static loc:LocKeyConverter.Instance}}" /></DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <!-- Farbe: darf jeder für sich wählen (auch im Self-Modus). Wir nehmen den Inline-ColorView
             (HSV-Rad, Palette, Hex-Feld direkt sichtbar) statt des Button-mit-Flyout-ColorPicker,
             damit man im Editor die Auswahl direkt sieht. Der VM-Hex-String wird per Konverter gemappt. -->
        <StackPanel Spacing="6">
          <TextBlock Text="{loc:Tr User_Color}" FontSize="12" Opacity="0.7" />
          <ColorView Color="{Binding SelectedColor, Converter={StaticResource HexToColorConverter}, Mode=TwoWay}"
                     HorizontalAlignment="Stretch"
                     IsAlphaEnabled="False"
                     IsAlphaVisible="False"
                     IsColorPaletteVisible="True"
                     IsColorPreviewVisible="True"
                     IsColorComponentsVisible="True" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowPassword}">
          <TextBlock Text="{Binding PasswordHint}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding Password}" PasswordChar="*" CornerRadius="6" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr User_AiStyleHint}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding AiStyleHint}" AcceptsReturn="True" Height="70"
                   TextWrapping="Wrap" CornerRadius="6"
                   PlaceholderText="{loc:Tr User_AiStyleHintPlaceholder}" />
          <TextBlock Text="{loc:Tr User_AiStyleHintHint}" FontSize="11" Opacity="0.55" TextWrapping="Wrap" />
        </StackPanel>

        <CheckBox IsChecked="{Binding ShowHints}" Content="{loc:Tr User_ShowHints}" />

        <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="#33C0392B" CornerRadius="6" Padding="10,8">
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="13" TextWrapping="Wrap" />
        </Border>

      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,12,Auto" Margin="0,16,0,0">
      <Button Grid.Column="0" Content="{loc:Tr Common_Delete}"
              Command="{Binding DeleteCommand}" IsVisible="{Binding CanDelete}"
              Padding="16,8" CornerRadius="6" Background="#C0392B" Foreground="White" />
      <Button Grid.Column="2" Content="{loc:Tr Common_Cancel}"
              Command="{Binding CancelCommand}" Padding="16,8" CornerRadius="6" />
      <Button Grid.Column="4" Content="{loc:Tr Common_Save}"
              Command="{Binding SaveCommand}" Padding="16,8" CornerRadius="6"
              Background="{DynamicResource SystemAccentColor}" Foreground="White" />
    </Grid>

  </Grid>
</UserControl>
