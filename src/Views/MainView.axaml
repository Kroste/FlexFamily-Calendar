<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlexFamilyCalendar.ViewModels"
             xmlns:views="using:FlexFamilyCalendar.Views"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.MainView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

  <Grid>

  <DockPanel>

    <!-- Kopfzeile (nur wenn angemeldet) -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsLoggedIn}"
            Padding="16,10"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="{DynamicResource AppHeaderBrush}">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Path Data="{StaticResource Icon.Calendar}"
                Fill="White" Stroke="White" StrokeThickness="0"
                Width="22" Height="22" Stretch="Uniform" />
          <TextBlock Text="{loc:Tr App_Title}"
                     FontSize="18" FontWeight="Bold"
                     Foreground="White"
                     VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <!-- Benachrichtigungs-Glocke mit Ungelesen-Badge -->
          <Button Command="{Binding OpenNotificationsCommand}"
                  Background="#33FFFFFF" BorderBrush="#55FFFFFF"
                  CornerRadius="6" Padding="10,5" VerticalAlignment="Center"
                  views:Hint.Text="{loc:Tr Hint_Main_Notifications}">
            <Grid>
              <Path Data="{StaticResource Icon.Bell}"
                    Fill="White" Width="15" Height="15" Stretch="Uniform" />
              <Border IsVisible="{Binding HasUnread}"
                      Background="#E74C3C" CornerRadius="8" MinWidth="16" Height="16"
                      Padding="4,0" Margin="0,-8,-10,0"
                      HorizontalAlignment="Right" VerticalAlignment="Top">
                <TextBlock Text="{Binding UnreadBadge}" FontSize="10" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Grid>
          </Button>
          <TextBlock Text="{Binding CurrentUserDisplay}"
                     Foreground="White" Opacity="0.85"
                     VerticalAlignment="Center" FontSize="13" />
          <Button Content="{loc:Tr Main_Admin}"
                  Command="{Binding OpenAdminCommand}"
                  IsVisible="{Binding IsAdmin}"
                  Foreground="White" Background="#33FFFFFF" BorderBrush="#55FFFFFF"
                  CornerRadius="6" Padding="12,5"
                  views:Hint.Text="{loc:Tr Hint_Main_Admin}" />
          <Button Content="{loc:Tr Main_MonthOverview}"
                  Command="{Binding OpenMonthOverviewCommand}"
                  Foreground="White" Background="#33FFFFFF" BorderBrush="#55FFFFFF"
                  CornerRadius="6" Padding="12,5"
                  views:Hint.Text="{loc:Tr Hint_Main_MonthOverview}" />
          <Button Content="{loc:Tr Main_HoursAccount}"
                  Command="{Binding OpenHoursAccountCommand}"
                  Foreground="White" Background="#33FFFFFF" BorderBrush="#55FFFFFF"
                  CornerRadius="6" Padding="12,5"
                  views:Hint.Text="{loc:Tr Hint_Main_HoursAccount}" />
          <Button Content="{loc:Tr Main_Profile}"
                  Command="{Binding OpenProfileCommand}"
                  Foreground="White" Background="#33FFFFFF" BorderBrush="#55FFFFFF"
                  CornerRadius="6" Padding="12,5"
                  views:Hint.Text="{loc:Tr Hint_Main_Profile}" />
          <Button Command="{Binding OpenInfoCommand}"
                  Foreground="White" Background="#33FFFFFF" BorderBrush="#55FFFFFF"
                  CornerRadius="6" Padding="10,5"
                  views:Hint.Text="{loc:Tr Hint_Main_Info}">
            <Path Data="{StaticResource Icon.Info}"
                  Fill="White" Width="15" Height="15" Stretch="Uniform" />
          </Button>
          <Button Content="{loc:Tr Main_Logout}"
                  Command="{Binding LogoutCommand}"
                  Foreground="White"
                  Background="#33FFFFFF"
                  BorderBrush="#55FFFFFF"
                  CornerRadius="6"
                  Padding="12,5"
                  views:Hint.Text="{loc:Tr Hint_Main_Logout}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Statusleiste -->
    <Border DockPanel.Dock="Bottom"
            Padding="12,5"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="{DynamicResource SystemControlBackgroundChromeLowBrush}">
      <TextBlock Text="{Binding StatusMessage}"
                 FontSize="12"
                 Opacity="0.75"
                 VerticalAlignment="Center" />
    </Border>

    <!-- Inhaltsfläche -->
    <Grid>
      <Border IsVisible="{Binding IsLoggedIn}">
        <views:CalendarView DataContext="{Binding CalendarVm}" />
      </Border>
      <Border IsVisible="{Binding IsNotLoggedIn}">
        <views:LoginView DataContext="{Binding LoginVm}" />
      </Border>
    </Grid>

  </DockPanel>

  <!-- Modal-Overlay für den Browser (kein Window verfügbar). Desktop nutzt diesen Pfad nicht.
       Liegt über dem DockPanel, deckt also auch Header und Statusleiste ab — Logout/Glocke
       sind während eines offenen Dialogs nicht klickbar. -->
  <Grid x:Name="DialogOverlay"
        Background="#80000000"
        IsVisible="False"
        ZIndex="100">
    <!-- Karte trägt KEIN festes MaxWidth/MaxHeight mehr — jeder UserControl bestimmt seine
         eigene Soll-Breite (MaxWidth pro Dialog). Margin zum Viewport-Rand verhindert, dass
         große Dialoge bündig an die Bildschirmkante anstoßen. -->
    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            CornerRadius="10"
            Margin="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BoxShadow="0 8 24 0 #66000000">
      <Grid>
        <ContentControl x:Name="DialogContent" />
        <!-- Browser-Modus: sichtbares Schließen-X (auf Desktop bleibt das OS-Window-X).
             "×" (U+00D7) statt "✕" (U+2715), weil letzteres in Inter ein Fallback-Glyph rendert. -->
        <Button Click="OnOverlayCloseClick"
                Content="×" FontSize="20" FontWeight="Bold"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,4,0" Padding="10,2"
                Background="Transparent" BorderThickness="0" />
      </Grid>
    </Border>
  </Grid>

  </Grid>
</UserControl>
