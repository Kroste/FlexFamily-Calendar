<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.AiSettingsView"
             x:CompileBindings="False">

  <Grid Margin="16" RowDefinitions="*,Auto" MaxWidth="520" HorizontalAlignment="Left">

    <StackPanel Grid.Row="0" Spacing="14">

      <StackPanel Spacing="4">
        <TextBlock Text="{loc:Tr Ai_Provider}" FontSize="12" Opacity="0.7" />
        <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}"
                  HorizontalAlignment="Stretch" />
      </StackPanel>

      <!-- Cloud-Provider: API-Schlüssel (maskiert) -->
      <StackPanel Spacing="4" IsVisible="{Binding RequiresKey}">
        <TextBlock Text="{loc:Tr Ai_ApiKey}" FontSize="12" Opacity="0.7" />
        <TextBox Text="{Binding ApiKey}" PasswordChar="*" CornerRadius="6"
                 PlaceholderText="{Binding KeyPlaceholder}" />
      </StackPanel>

      <!-- Lokale Llama: Endpoint statt Schlüssel -->
      <StackPanel Spacing="4" IsVisible="{Binding IsLocal}">
        <TextBlock Text="{loc:Tr Ai_Endpoint}" FontSize="12" Opacity="0.7" />
        <TextBox Text="{Binding ApiKey}" CornerRadius="6"
                 PlaceholderText="http://localhost:11434" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="{loc:Tr Ai_Model}" FontSize="12" Opacity="0.7" />
        <TextBox Text="{Binding Model}" CornerRadius="6"
                 PlaceholderText="{loc:Tr Ai_ModelPlaceholder}" />
      </StackPanel>

      <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
              Background="#22808080" CornerRadius="6" Padding="10,8">
        <TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap" />
      </Border>

    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
      <Button Content="{loc:Tr Ai_Test}" Command="{Binding TestCommand}" Padding="16,8" CornerRadius="6" />
      <Button Content="{loc:Tr Common_Save}" Command="{Binding SaveCommand}" Padding="16,8" CornerRadius="6"
              Background="{DynamicResource SystemAccentColor}" Foreground="White" />
    </StackPanel>

  </Grid>
</UserControl>
