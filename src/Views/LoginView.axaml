<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlexFamilyCalendar.ViewModels"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             xmlns:views="using:FlexFamilyCalendar.Views"
             x:Class="FlexFamilyCalendar.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             x:CompileBindings="False">

  <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            CornerRadius="12"
            Padding="40,36"
            Width="380"
            BoxShadow="0 4 24 0 #40000000">
      <StackPanel Spacing="20">

        <!-- Sprachwahl -->
        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                  SelectedItem="{Binding SelectedLanguage}"
                  HorizontalAlignment="Right" MinWidth="120">
          <ComboBox.ItemTemplate>
            <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- Logo / Titel -->
        <StackPanel HorizontalAlignment="Center" Spacing="4">
          <Path Data="{StaticResource Icon.Calendar}"
                Fill="{DynamicResource SystemControlForegroundAccentBrush}"
                Width="40" Height="40" Stretch="Uniform"
                HorizontalAlignment="Center" />
          <TextBlock Text="{loc:Tr App_Title}"
                     FontSize="22" FontWeight="Bold"
                     HorizontalAlignment="Center" />
          <TextBlock IsVisible="{Binding IsFirstRun}"
                     Text="{loc:Tr Login_FirstRunSubtitle}"
                     FontSize="13" Opacity="0.6"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Felder -->
        <StackPanel Spacing="12">
          <StackPanel Spacing="4" IsVisible="{Binding IsFirstRun}">
            <TextBlock Text="{loc:Tr Login_DisplayName}" FontSize="12" Opacity="0.7" />
            <TextBox Text="{Binding DisplayName}"
                     PlaceholderText="{loc:Tr Login_DisplayNamePlaceholder}"
                     CornerRadius="6" />
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="{loc:Tr Login_Username}" FontSize="12" Opacity="0.7" />
            <TextBox Text="{Binding Username}"
                     PlaceholderText="{loc:Tr Login_Username}"
                     CornerRadius="6" />
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="{loc:Tr Login_Password}" FontSize="12" Opacity="0.7" />
            <TextBox Text="{Binding Password}"
                     PlaceholderText="{loc:Tr Login_Password}"
                     PasswordChar="*"
                     CornerRadius="6" />
          </StackPanel>

          <CheckBox IsChecked="{Binding RememberMe}" Content="{loc:Tr Login_RememberMe}"
                    views:Hint.Text="{loc:Tr Hint_Login_RememberMe}" />
        </StackPanel>

        <!-- Fehlermeldung -->
        <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="#33C0392B" CornerRadius="6" Padding="10,8">
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="13" />
        </Border>

        <!-- Buttons -->
        <Button IsVisible="{Binding !IsFirstRun}"
                Content="{loc:Tr Login_SignIn}"
                Command="{Binding LoginCommand}"
                IsEnabled="{Binding !IsLoading}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Height="40"
                CornerRadius="6"
                Background="{DynamicResource SystemAccentColor}"
                Foreground="White" />

        <Button IsVisible="{Binding IsFirstRun}"
                Content="{loc:Tr Login_CreateAdmin}"
                Command="{Binding CreateAdminCommand}"
                IsEnabled="{Binding !IsLoading}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Height="40"
                CornerRadius="6"
                Background="#27AE60"
                Foreground="White" />

        <!-- Ladeindikator -->
        <ProgressBar IsVisible="{Binding IsLoading}"
                     IsIndeterminate="True"
                     Height="3"
                     CornerRadius="2" />

        <!-- Verbindungs-Modus: lokal oder Server (URL einstellen) -->
        <Button Content="{Binding ConnectionLabel}" Click="OnConnectionClick"
                Background="Transparent" BorderThickness="0"
                HorizontalAlignment="Center" Padding="6,4" CornerRadius="6"
                FontSize="11" Opacity="0.65" Cursor="Hand"
                views:Hint.Text="{loc:Tr Hint_Login_Connection}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
