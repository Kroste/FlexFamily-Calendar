<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:FlexFamilyCalendar.Localization"
             x:Class="FlexFamilyCalendar.Views.SettingsView"
             x:CompileBindings="False">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
  <StackPanel Margin="16" Spacing="14" MaxWidth="440" HorizontalAlignment="Left">

    <StackPanel Spacing="4">
      <TextBlock Text="{loc:Tr Holiday_Region}" FontSize="12" Opacity="0.7" />
      <ComboBox ItemsSource="{Binding States}" SelectedItem="{Binding SelectedState}"
                HorizontalAlignment="Stretch">
        <ComboBox.ItemTemplate>
          <DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <StackPanel Spacing="4">
      <TextBlock Text="{loc:Tr Settings_OvernightHours}" FontSize="12" Opacity="0.7" />
      <TextBox Text="{Binding OvernightHours}" CornerRadius="6" />
    </StackPanel>

    <!-- E-Mail-Versand (SMTP) — nur im Local-Modus (Desktop+JSON). Im Server-/Browser-Modus läuft
         SMTP serverseitig über die ENV-Variablen Smtp__Host etc., dieses UI würde nur verwirren. -->
    <StackPanel Spacing="14" IsVisible="{Binding ShowSmtpSection}">
      <TextBlock Text="{loc:Tr Settings_Smtp}" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" />

      <StackPanel Spacing="4">
        <TextBlock Text="{loc:Tr Settings_SmtpFrom}" FontSize="12" Opacity="0.7" />
        <TextBox Text="{Binding SmtpFrom}" CornerRadius="6" PlaceholderText="plan@example.com" />
      </StackPanel>

      <Grid ColumnDefinitions="*,12,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="{loc:Tr Settings_SmtpHost}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding SmtpHost}" CornerRadius="6" PlaceholderText="smtp.example.com" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="4" Width="80">
          <TextBlock Text="{loc:Tr Settings_SmtpPort}" FontSize="12" Opacity="0.7" />
          <TextBox Text="{Binding SmtpPort}" CornerRadius="6" />
        </StackPanel>
      </Grid>

      <StackPanel Spacing="4">
        <TextBlock Text="{loc:Tr Settings_SmtpUser}" FontSize="12" Opacity="0.7" />
        <TextBox Text="{Binding SmtpUser}" CornerRadius="6" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="{loc:Tr Settings_SmtpPassword}" FontSize="12" Opacity="0.7" />
        <TextBox Text="{Binding SmtpPassword}" PasswordChar="*" CornerRadius="6"
                 PlaceholderText="{loc:Tr Settings_SmtpPasswordHint}" />
      </StackPanel>

      <CheckBox Content="{loc:Tr Settings_SmtpSsl}" IsChecked="{Binding SmtpUseSsl}" />
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="12">
      <Button Content="{loc:Tr Common_Save}" Command="{Binding SaveCommand}"
              Padding="16,8" CornerRadius="6"
              Background="{DynamicResource SystemAccentColor}" Foreground="White" />
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                 Foreground="#27AE60" FontSize="13" />
    </StackPanel>

  </StackPanel>
  </ScrollViewer>
</UserControl>
