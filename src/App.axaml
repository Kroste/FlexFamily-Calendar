<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cv="using:FlexFamilyCalendar.Converters"
             x:Class="FlexFamilyCalendar.App"
             xmlns:local="using:FlexFamilyCalendar"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://FlexFamilyCalendar/Styles/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <cv:ColorStringToBrushConverter x:Key="ColorStringToBrushConverter" />
            <!-- Feste Markenfarbe für den Header (nicht benutzerabhängig) -->
            <SolidColorBrush x:Key="AppHeaderBrush" Color="#1A237E" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <!-- Avalonia.Controls.ColorPicker bringt seine Styles in einem eigenen Ressourcen-Sheet mit;
             ohne den Include ist der ColorPicker/ColorView im Dialog unsichtbar. -->
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
        <StyleInclude Source="avares://FlexFamilyCalendar/Styles/AppStyles.axaml" />
        <StyleInclude Source="avares://FlexFamilyCalendar/Views/ChromeWindow.axaml" />
    </Application.Styles>
</Application>
