<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cv="using:FlexFamilyCalendar.Converters"
             x:Class="FlexFamilyCalendar.App"
             xmlns:local="using:FlexFamilyCalendar"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <cv:ColorStringToBrushConverter x:Key="ColorStringToBrushConverter" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#2E86C1" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://FlexFamilyCalendar/Styles/AppStyles.axaml" />
    </Application.Styles>
</Application>
