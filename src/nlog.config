<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

  <targets>
    <target xsi:type="File"
            name="logfile"
            fileName="${specialfolder:folder=LocalApplicationData}/FlexFamilyCalendar/logs/flexfamily-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true} | ${logger:shortName=true} | ${message}${exception:format=toString,Data:separator=&#13;&#10;}"
            archiveEvery="Day"
            archiveNumbering="Date"
            maxArchiveFiles="30"
            encoding="utf-8"
            createDirs="true" />

    <target xsi:type="Console"
            name="console"
            layout="${time} | ${level:uppercase=true} | ${message}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Debug" writeTo="console" />
    <logger name="*" minlevel="Info" writeTo="logfile" />
  </rules>
</nlog>
