# Automatisches HTTPS (Let's Encrypt) + Single-Origin: SPA und API teilen sich flexfamily.cloud.
# /api/* und /health gehen an den API-Container (intern Port 8080). Alles andere = WASM-SPA
# aus /srv/spa (kommt aus Stufe 2 der Caddy.Dockerfile). SPA-Routing fällt auf /index.html zurück.
flexfamily.cloud {
    @api path /api/* /health
    handle @api {
        reverse_proxy api:8080
    }
    handle {
        root * /srv/spa
        try_files {path} /index.html
        file_server
    }
}
