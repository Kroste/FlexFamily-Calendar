# Automatisches HTTPS (Let's Encrypt) + Single-Origin: SPA und API teilen sich flexfamily.cloud.
# /api/* und /health gehen an den API-Container (intern Port 8080). Alles andere = WASM-SPA
# aus /srv/spa (kommt aus Stufe 2 der Caddy.Dockerfile). SPA-Routing fällt auf /index.html zurück.
flexfamily.cloud {
    @api path /api/* /health
    handle @api {
        reverse_proxy api:8080
    }
    handle {
        root * /srv/spa

        # SRI-Schutz: nach einem Update darf der Browser KEIN altes index.html / Manifest aus
        # seinem Cache verwenden, sonst referenziert er WASM-Dateien mit veralteten integrity-
        # Hashes und blockt sie ("Failed to find a valid digest …"). WASM/JS-Assets darunter
        # bleiben cachable — der Browser revalidiert sie über ihre Hashes.
        @no-cache {
            path /
            path /index.html
            path /_framework/*.json
            path /_framework/dotnet.js
        }
        header @no-cache Cache-Control "no-cache, must-revalidate"

        try_files {path} /index.html
        file_server
    }
}
